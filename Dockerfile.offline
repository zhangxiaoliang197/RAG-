FROM node:20-bullseye-slim

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends openjdk-17-jdk-headless ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci

COPY . .

ENV PORT=3001
EXPOSE 5173 3001

VOLUME ["/app/data"]

CMD ["npm", "run", "dev:docker"]

